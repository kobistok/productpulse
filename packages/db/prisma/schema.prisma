generator client {
  provider      = "prisma-client-js"
  // linux-musl-openssl-3.0.x is required for Alpine-based Docker images (Cloud Run)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum GitProvider {
  GITHUB
  GITLAB
}

model Organization {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  memberships      Membership[]
  productLines     ProductLine[]
  invites          Invite[]
  dashboardInvites DashboardInvite[]
  orgSkills        OrgSkill[]
  contentAgents    ContentAgent[]
  zendeskConfig    ZendeskConfig?
  googleDriveConfig GoogleDriveConfig?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model User {
  id          String       @id // Firebase UID
  email       String       @unique
  name        String?
  avatarUrl   String?
  memberships Membership[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  role      Role         @default(MEMBER)
  user      User         @relation(fields: [userId], references: [id])
  org       Organization @relation(fields: [orgId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([userId, orgId])
}

// Team invite — admin generates a link, shares it however they want
model Invite {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  role      Role         @default(MEMBER)
  email     String?      // invited user's email — if set, only this email can accept
  token     String       @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdBy String // userId of admin who generated it
  createdAt DateTime     @default(now())
}

model ProductLine {
  id             String          @id @default(cuid())
  orgId          String
  org            Organization    @relation(fields: [orgId], references: [id])
  name           String
  description    String?
  slug           String
  agent          Agent?
  gitTriggers    GitTrigger[]
  triggerEvents  TriggerEvent[]
  updates        Update[]
  circleCIConfig CircleCIConfig?
  jiraConfig     JiraConfig?
  createdBy      String // userId
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([orgId, slug])
}

// 1 agent per product line — owned by the user who created it
model Agent {
  id             String      @id @default(cuid())
  productLineId  String      @unique
  productLine    ProductLine @relation(fields: [productLineId], references: [id])
  systemPrompt   String?     @db.Text // deprecated — prompt is now internal
  productContext String?     @db.Text // optional context provided by the user
  filterRule     String?     @db.Text // optional filter: agent skips if condition not met
  model          String      @default("claude-sonnet-4-6")
  ownerId        String // userId — the "manager" of this agent
  createdBy      String // userId
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model GitTrigger {
  id            String         @id @default(cuid())
  productLineId String
  productLine   ProductLine    @relation(fields: [productLineId], references: [id])
  provider      GitProvider    @default(GITHUB)
  webhookSecret String // HMAC secret for GitHub; plain token for GitLab
  repoUrl       String?
  branchFilter  String? // e.g. "main", "release/*"
  pathFilter    String? // e.g. "src/payments/**"
  active        Boolean        @default(true)
  fireCount     Int            @default(0)
  events        TriggerEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Log entry for every webhook hit or manual run
model TriggerEvent {
  id            String      @id @default(cuid())
  productLineId String
  triggerId     String? // null for manual runs
  source        String // "webhook" | "manual"
  status        String // "queued" | "skipped" | "failed"
  detail        String? // skip reason or error message
  repo          String?
  branch        String?
  createdAt     DateTime    @default(now())

  agentDecision  String?   // "update_created" | "skipped" — set by worker after agent runs
  workerDetail   String?   // agent skip reason + integration summary — set by worker
  updateContent  String?   @db.Text // content generated by the agent for this specific run
  agentInputData Json?     // full input context: commits, filesChanged, diffSummary, jira, circleCI

  productLine   ProductLine @relation(fields: [productLineId], references: [id], onDelete: Cascade)
  trigger       GitTrigger? @relation(fields: [triggerId], references: [id], onDelete: SetNull)
}

model CircleCIConfig {
  id            String      @id @default(cuid())
  productLineId String      @unique
  productLine   ProductLine @relation(fields: [productLineId], references: [id])
  apiToken      String
  projectSlug   String // e.g. "gh/myorg/myrepo"
  branch        String      @default("main")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model JiraConfig {
  id               String      @id @default(cuid())
  productLineId    String      @unique
  productLine      ProductLine @relation(fields: [productLineId], references: [id])
  baseUrl          String // e.g. "https://myco.atlassian.net" — used for API calls
  atlassianDomain  String? // e.g. "myco.atlassian.net" — used for ticket browse links
  email            String
  apiToken         String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// One update per product line per ISO week (upserted by agent)
model Update {
  id            String      @id @default(cuid())
  productLineId String
  productLine   ProductLine @relation(fields: [productLineId], references: [id])
  isoWeek       Int // 1–53
  year          Int
  content       String      @db.Text // markdown
  commitShas    String[]
  diffSummary   String?     @db.Text
  agentId       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([productLineId, isoWeek, year])
}

model OrgSkill {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  name      String
  content   String       @db.Text
  createdBy String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ContentAgent {
  id              String          @id @default(cuid())
  orgId           String
  org             Organization    @relation(fields: [orgId], references: [id])
  name            String
  specificContext String?         @db.Text
  outputTypes     String[]
  productLineIds  String[]
  model           String          @default("claude-sonnet-4-6")
  shareToken      String?         @unique
  outputs         ContentOutput[]
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ContentOutput {
  id              String       @id @default(cuid())
  contentAgentId  String
  contentAgent    ContentAgent @relation(fields: [contentAgentId], references: [id], onDelete: Cascade)
  outputType      String
  title           String
  content         String       @db.Text
  status          String       @default("draft")
  isoWeek         Int
  year            Int
  zendeskArticles String?      @db.Text // JSON: Array<{ id: number; title: string; url: string }>
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ZendeskConfig {
  id        String       @id @default(cuid())
  orgId     String       @unique
  org       Organization @relation(fields: [orgId], references: [id])
  subdomain String
  email     String
  apiToken  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model GoogleDriveConfig {
  id           String       @id @default(cuid())
  orgId        String       @unique
  org          Organization @relation(fields: [orgId], references: [id])
  accessToken  String       @db.Text
  refreshToken String       @db.Text
  expiresAt    DateTime
  email        String       // Google account email — shown in UI
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// Shareable read-only dashboard link (no login required)
model DashboardInvite {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  token     String       @unique @default(cuid())
  label     String? // friendly name e.g. "Investors", "Board"
  expiresAt DateTime?
  createdBy String // userId
  createdAt DateTime     @default(now())
}
