# ─── Database ────────────────────────────────────────────────────────────────
# Cloud SQL (PostgreSQL) via Cloud SQL Auth Proxy or connector
DATABASE_URL="postgresql://user:password@localhost:5432/productpulse"

# ─── Firebase Client (public — safe to expose) ───────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""

# ─── Firebase Admin (private — server only) ──────────────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── GCP ─────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=""
GCP_LOCATION="us-central1"
CLOUD_TASKS_QUEUE="agent-jobs"

# ─── Worker ──────────────────────────────────────────────────────────────────
# URL of this app (used by Cloud Tasks to call back the worker route)
WORKER_URL="http://localhost:3000"
# Shared secret between Cloud Tasks and the worker route
WORKER_AUTH_TOKEN=""
